---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  photoSrc?: string;
}

const { eyebrow, title, intro, photoSrc } = Astro.props;
---

<section class:list={["page-hero", photoSrc && "page-hero-photo"]}>
  {photoSrc && <img class="page-hero-bg" src={photoSrc} alt="" loading="eager" decoding="async" />}
  <div class="container page-hero-inner">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="page-title">{title}</h1>
    {intro && <p class="page-intro">{intro}</p>}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    padding: 72px 0 56px;
    border-bottom: 1px solid var(--color-border);
    background:
      radial-gradient(circle at top right, var(--color-brand-muted), transparent 24rem),
      linear-gradient(180deg, #faf8f4 0%, #f5f3ef 100%);
  }

  .page-hero-photo {
    overflow: hidden;
    color: #fff;
    border-bottom-color: rgb(255 255 255 / 12%);
    background: var(--color-navy);
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.34;
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
  }

  .page-hero-photo .eyebrow {
    color: var(--color-brand);
  }

  .page-hero-photo .page-title,
  .page-hero-photo .page-intro {
    color: #fff;
  }

  .page-hero-photo .page-intro {
    color: rgb(255 255 255 / 76%);
  }

  @media (max-width: 820px) {
    .page-hero {
      padding: 56px 0 40px;
    }
  }
</style>
