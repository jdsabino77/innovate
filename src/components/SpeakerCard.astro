---
interface Props {
  name: string;
  credentials?: string;
  role: string;
  bio: string;
  photo: string;
  photoAlt: string;
  sourceUrl?: string;
}

const { name, credentials, role, bio, photo, photoAlt, sourceUrl } = Astro.props;
---

<article class="card speaker-card">
  <div class="speaker-photo-frame">
    <img src={photo} alt={photoAlt} loading="lazy" decoding="async" width="320" height="400" />
  </div>
  <div class="speaker-body">
    <h3>{name}</h3>
    {credentials && <p class="speaker-credentials">{credentials}</p>}
    <p class="speaker-role">{role}</p>
    <p class="speaker-bio">{bio}</p>
    {
      sourceUrl && (
        <a class="speaker-profile" href={sourceUrl} target="_blank" rel="noopener noreferrer">
          Profile
        </a>
      )
    }
  </div>
</article>

<style>
  .speaker-card {
    display: grid;
    gap: 0;
    padding: 0;
    overflow: hidden;
  }

  .speaker-photo-frame {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-brand-soft);
  }

  .speaker-photo-frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .speaker-body {
    display: grid;
    gap: 8px;
    padding: 22px 24px 24px;
  }

  .speaker-body h3 {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .speaker-credentials {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .speaker-role {
    margin: 0;
    color: var(--color-brand);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .speaker-bio {
    margin: 4px 0 0;
    line-height: 1.55;
  }

  .speaker-profile {
    margin-top: 6px;
    color: var(--color-navy);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: rgb(201 169 98 / 60%);
    text-underline-offset: 3px;
  }

  .speaker-profile:hover,
  .speaker-profile:focus-visible {
    color: var(--color-brand);
  }
</style>
