---
import type { VenuePhoto } from "../lib/venue";

interface Props {
  photos: VenuePhoto[];
}

const { photos } = Astro.props;
---

<div class="venue-collage">
  {
    photos.map((photo, index) => (
      <figure class:list={["venue-collage-item", index === 0 && "venue-collage-primary"]}>
        <img src={photo.src} alt={photo.alt} loading={index === 0 ? "eager" : "lazy"} decoding="async" />
        <figcaption>{photo.caption}</figcaption>
      </figure>
    ))
  }
</div>

<style>
  .venue-collage {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 14px;
    align-items: stretch;
  }

  .venue-collage-item {
    position: relative;
    overflow: hidden;
    margin: 0;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
  }

  .venue-collage-primary {
    grid-row: span 2;
    min-height: 420px;
  }

  .venue-collage-item img {
    width: 100%;
    height: 100%;
    min-height: 200px;
    object-fit: cover;
  }

  .venue-collage-item figcaption {
    position: absolute;
    right: 12px;
    bottom: 12px;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgb(15 15 15 / 72%);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .venue-collage {
      grid-template-columns: 1fr;
    }

    .venue-collage-primary {
      grid-row: auto;
      min-height: 280px;
    }
  }
</style>
