---
interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  class?: string;
  variant?: "default" | "soft" | "dark";
}

const { eyebrow, title, intro, class: className = "", variant = "default" } = Astro.props;
---

<section class:list={["section", `section-${variant}`, className]}>
  <div class="container">
    {(eyebrow || title || intro) && (
      <div class="section-heading">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {title && <h2>{title}</h2>}
        {intro && <p>{intro}</p>}
      </div>
    )}
    <slot />
  </div>
</section>

<style>
  .section {
    padding: 72px 0;
  }

  .section-soft {
    background: var(--color-soft);
  }

  .section-dark {
    background: var(--color-navy);
    color: #fff;
  }

  .section-dark .section-heading h2,
  .section-dark .section-heading p:not(.eyebrow) {
    color: rgb(255 255 255 / 82%);
  }

  .section-dark .section-heading h2 {
    color: #fff;
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 28px;
  }

  .section-heading h2 {
    margin: 0;
    color: var(--color-navy);
    font-size: clamp(2rem, 4vw, 3.35rem);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .section-heading p:not(.eyebrow) {
    margin: 16px 0 0;
    color: var(--color-muted);
    font-size: 1.08rem;
  }

  @media (max-width: 820px) {
    .section {
      padding: 48px 0;
    }
  }
</style>
