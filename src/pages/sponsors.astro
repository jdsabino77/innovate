---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Button from "../components/Button.astro";
import Section from "../components/Section.astro";
import ExhibitorLogoCard from "../components/ExhibitorLogoCard.astro";
import sponsorsData from "../data/sponsors.json";
import { eventConfig } from "../lib/event-config";

const { page, host, exhibitors, tiers } = sponsorsData;
const contactEmail = page.contactEmail || eventConfig.contactEmail;
const featuredExhibitors = exhibitors
  .filter((exhibitor) => exhibitor.featured !== false)
  .sort((a, b) => a.order - b.order);
---

<BaseLayout
  title="Exhibitors & Sponsors"
  description={`Confirmed industry partners and sponsorship opportunities for ${eventConfig.eventNameLong}, hosted by ${eventConfig.host}.`}
  canonicalPath="/sponsors"
>
  <PageHero eyebrow={page.eyebrow} title={page.title} intro={page.intro} />
  <Section>
    {
      host && (
        <div class="host-strip">
          <span class="host-label">{host.label}</span>
          <a class="host-link" href={host.url} target="_blank" rel="noopener noreferrer">
            <img class="host-logo" src={host.logo} alt={host.logoAlt ?? host.name} width="160" height="48" />
          </a>
        </div>
      )
    }
    <h2 class="section-heading">{page.exhibitorsHeading}</h2>
    <div class="exhibitor-grid">
      {featuredExhibitors.map((exhibitor) => <ExhibitorLogoCard {...exhibitor} />)}
    </div>
    {page.moreComingNote && <p class="more-coming">{page.moreComingNote}</p>}
  </Section>

  <Section variant="soft">
    <h2 class="section-heading">{page.tiersHeading}</h2>
    <p class="tiers-intro">{page.tiersIntro}</p>
    <div class="tier-grid">
      {
        tiers.map((tier) => (
          <article class="card tier-card">
            <h3>{tier.name}</h3>
            <p>{tier.description}</p>
            <p class="tier-availability">
              {tier.available === 1 ? "1 slot available" : `${tier.available} slots available`}
            </p>
          </article>
        ))
      }
    </div>
    <div class="sponsor-cta">
      {
        contactEmail ? (
          <Button href={`mailto:${contactEmail}?subject=${encodeURIComponent(`${eventConfig.eventName} 2027 sponsorship inquiry`)}`}>
            Email {contactEmail}
          </Button>
        ) : (
          <Button href="/contact">Contact the team</Button>
        )
      }
    </div>
  </Section>
</BaseLayout>

<style>
  .host-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px 16px;
    margin: 0 0 28px;
    padding: 16px 20px;
    border: 1px solid color-mix(in srgb, var(--color-navy) 12%, transparent);
    border-radius: 12px;
    background: color-mix(in srgb, var(--color-soft) 70%, white);
  }

  .host-label {
    color: var(--color-muted);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .host-link {
    display: inline-flex;
    align-items: center;
  }

  .host-logo {
    display: block;
    width: auto;
    max-width: 160px;
    height: 48px;
    object-fit: contain;
  }

  .section-heading {
    margin: 0 0 18px;
    color: var(--color-navy);
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    line-height: 1.15;
  }

  .exhibitor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr));
    gap: 16px;
  }

  .more-coming {
    margin: 24px 0 0;
    color: var(--color-muted);
    font-size: 0.95rem;
    text-align: center;
  }

  .tiers-intro {
    margin: 0 0 18px;
    max-width: 720px;
    color: var(--color-muted);
  }

  .tier-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
    gap: 16px;
  }

  .tier-card {
    display: grid;
    gap: 10px;
  }

  .tier-card h3 {
    margin: 0;
    color: var(--color-navy);
    font-size: 1.15rem;
  }

  .tier-card p {
    margin: 0;
  }

  .tier-availability {
    color: var(--color-brand);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sponsor-cta {
    margin-top: 22px;
  }

  @media (max-width: 820px) {
    .exhibitor-grid,
    .tier-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
