---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Button from "../components/Button.astro";
import Section from "../components/Section.astro";
import hotelInfo from "../data/hotel-information.json";
import { eventConfig } from "../lib/event-config";

const { page, venueNote, roomBlockNote, hotels, tips } = hotelInfo;
---

<BaseLayout
  title="Hotel Information"
  description={`Hotel and travel information for ${eventConfig.eventName} — ${eventConfig.eventDateDisplay} at ${eventConfig.venue}, Toronto.`}
  canonicalPath="/hotel-information"
>
  <PageHero eyebrow={page.eyebrow} title={page.title} intro={page.intro} />
  <Section>
    <div class="content hotel-content">
      <p class="hotel-note">{venueNote}</p>
      <div class="surface hotel-block-note">
        <h2>Room blocks</h2>
        <p>{roomBlockNote}</p>
      </div>
      <h2>Suggested hotels</h2>
      <div class="hotel-grid">
        {
          hotels.map((hotel) => (
            <article class="card hotel-card">
              <h3>{hotel.name}</h3>
              <p class="hotel-distance">{hotel.distance}</p>
              <p>{hotel.note}</p>
              <a href={hotel.url} target="_blank" rel="noopener noreferrer">
                Visit website
              </a>
            </article>
          ))
        }
      </div>
      <h2>Travel tips</h2>
      <ul>
        {tips.map((tip) => <li>{tip}</li>)}
      </ul>
      <div class="hotel-actions">
        <Button href="/register">Register Now</Button>
        <Button href="/venue" variant="secondary">Venue details</Button>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .hotel-content {
    max-width: 920px;
  }

  .hotel-note {
    margin: 0;
    color: var(--color-muted);
    font-size: 1.05rem;
  }

  .hotel-block-note {
    padding: 22px 24px;
    margin-top: 22px;
  }

  .hotel-block-note h2 {
    margin: 0 0 8px;
    font-size: 1.2rem;
  }

  .hotel-block-note p {
    margin: 0;
  }

  .hotel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
    gap: 16px;
    margin-top: 12px;
  }

  .hotel-card {
    display: grid;
    gap: 8px;
  }

  .hotel-card h3 {
    margin: 0;
    font-size: 1.1rem;
  }

  .hotel-distance {
    margin: 0;
    color: var(--color-brand);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hotel-card a {
    margin-top: 4px;
    color: var(--color-navy);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: rgb(201 169 98 / 60%);
    text-underline-offset: 3px;
  }

  .hotel-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  @media (max-width: 820px) {
    .hotel-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
