---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/Section.astro";
import schedule from "../data/schedule.json";
import { eventConfig } from "../lib/event-config";
---

<BaseLayout
  title="Schedule"
  description={`Draft schedule for ${eventConfig.eventName} on ${eventConfig.eventDateDisplay}.`}
  canonicalPath="/schedule"
>
  <PageHero
    eyebrow="Schedule"
    title="Draft program for Innovate 2027"
    intro={`${eventConfig.eventDateDisplay} at ${eventConfig.venue}. ${schedule.note}`}
  />
  <Section>
    <p class="note">{schedule.note}</p>
    <ol class="timeline">
      {
        schedule.sessions.map((session) => (
          <li class="timeline-item card">
            <p class="timeline-time">{session.time}</p>
            <div>
              <h3>{session.title}</h3>
              <p>{session.detail}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </Section>
</BaseLayout>

<style>
  .timeline {
    display: grid;
    gap: 14px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }

  .timeline-time {
    margin: 0;
    color: var(--color-brand);
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .timeline-item h3 {
    margin: 0 0 8px;
    color: var(--color-navy);
    font-size: 1.15rem;
  }

  .timeline-item p:last-child {
    margin: 0;
    color: var(--color-muted);
  }

  @media (max-width: 720px) {
    .timeline-item {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
