---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Button from "../components/Button.astro";
import Section from "../components/Section.astro";
import TicketTierCard from "../components/TicketTierCard.astro";
import TicketTailorWidget from "../components/TicketTailorWidget.astro";
import ticketsData from "../data/tickets.json";
import { eventConfig, isTicketingOpen } from "../lib/event-config";

const { page, tiers } = ticketsData;
const { ticketing } = eventConfig;
const registrationOpen = isTicketingOpen();
const heroIntro = registrationOpen ? page.introOpen : page.introClosed;
---

<BaseLayout
  title="Register"
  description={`Register for ${eventConfig.eventNameLong} on ${eventConfig.eventDateDisplay}.`}
  canonicalPath="/register"
>
  <PageHero
    eyebrow="Register"
    title="Reserve your seat at Innovate"
    intro={`Join us on ${eventConfig.eventDateDisplay} at ${eventConfig.venue}. ${heroIntro}`}
  />
  <Section>
    <h2 class="section-heading">Conference passes</h2>
    <div class="ticket-tier-grid">
      {tiers.map((tier) => <TicketTierCard {...tier} />)}
    </div>

    {
      registrationOpen ? (
        <div class="registration-checkout surface">
          <h3 class="checkout-heading">Complete your purchase</h3>
          {ticketing.embedUrl ? (
            <TicketTailorWidget embedUrl={ticketing.embedUrl} />
          ) : (
            <div class="checkout-fallback">
              <p>Select your pass and check out securely on Ticket Tailor.</p>
              <Button href={ticketing.checkoutUrl} target="_blank" rel="noopener noreferrer">
                Buy passes on Ticket Tailor
              </Button>
            </div>
          )}
          <p class="registration-footnote">{page.footnote}</p>
        </div>
      ) : (
        <div class="registration-placeholder surface">
          <h3>Registration opens soon</h3>
          <p>
            Passes will be sold through Ticket Tailor with QR code check-in. Pricing and early-bird
            windows will be announced here when sales go live.
          </p>
          <div class="registration-actions">
            <Button href={`mailto:${eventConfig.contactEmail}?subject=${encodeURIComponent(`${eventConfig.eventName} 2027 — registration inquiry`)}`}>
              Email {eventConfig.contactEmail}
            </Button>
            <Button href="/schedule" variant="secondary">Review the schedule</Button>
          </div>
        </div>
      )
    }
  </Section>
</BaseLayout>

<style>
  .section-heading {
    margin: 0 0 18px;
    color: var(--color-navy);
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    line-height: 1.15;
  }

  .ticket-tier-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .registration-checkout,
  .registration-placeholder {
    padding: 24px;
  }

  .checkout-heading,
  .registration-placeholder h3 {
    margin: 0 0 12px;
    color: var(--color-navy);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
  }

  .checkout-fallback {
    display: grid;
    gap: 16px;
    justify-items: start;
  }

  .checkout-fallback p,
  .registration-placeholder p {
    margin: 0;
    color: var(--color-muted);
    max-width: 640px;
  }

  .registration-footnote {
    margin: 20px 0 0;
    color: var(--color-muted);
    font-size: 0.88rem;
  }

  .registration-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  @media (max-width: 820px) {
    .ticket-tier-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
