---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import CtaBand from "../components/CtaBand.astro";
import VenueCollage from "../components/VenueCollage.astro";
import home from "../data/home.json";
import schedule from "../data/schedule.json";
import { siteDescription } from "../lib/event-config";
import { venue, getFeaturedPhotos, getVenuePhoto } from "../lib/venue";

const aboutImage = home.about.image
  ? { src: home.about.image, alt: home.about.imageAlt }
  : getVenuePhoto(venue.aboutFeatured);
const featuredVenuePhotos = getFeaturedPhotos();
const agendaPreview = schedule.sessions.slice(0, 4);
---

<BaseLayout title="Innovate" description={siteDescription} overlayHeader>
  <Hero />

  <Section class="about-section">
    <div class="about-grid">
      <div class="about-copy">
        <p class="eyebrow">{home.about.eyebrow}</p>
        <h2 class="about-title">{home.about.title}</h2>
        <p class="about-lead">{home.about.lead}</p>
        <div class="about-body">
          <p>{home.about.body}</p>
          {home.about.bodySecondary && <p>{home.about.bodySecondary}</p>}
        </div>
        {
          home.about.highlights && (
            <ul class="about-highlights">
              {home.about.highlights.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )
        }
        <div class="about-actions">
          <Button href="/register">Register</Button>
          <Button href="/speakers" variant="secondary">Meet the faculty</Button>
        </div>
      </div>
      {
        aboutImage && (
          <figure class="image-frame image-frame-accent about-media">
            <img src={aboutImage.src} alt={aboutImage.alt} loading="lazy" decoding="async" />
          </figure>
        )
      }
    </div>
  </Section>

  <Section
    variant="soft"
    eyebrow={home.experience.eyebrow}
    title={home.experience.title}
    intro={home.experience.intro}
  >
    <div class="grid grid-3">
      {home.experience.items.map((item) => <ExperienceCard {...item} />)}
    </div>
  </Section>

  <Section eyebrow={home.agenda.eyebrow} title={home.agenda.title} intro={home.agenda.intro}>
    <ol class="agenda-preview">
      {
        agendaPreview.map((session) => (
          <li class="agenda-preview-item card">
            <p class="agenda-time">{session.time}</p>
            <div>
              <h3>{session.title}</h3>
              <p>{session.detail}</p>
            </div>
          </li>
        ))
      }
    </ol>
    <div class="agenda-actions">
      <Button href="/schedule">{home.agenda.cta}</Button>
      <Button href="/register" variant="secondary">Register</Button>
    </div>
  </Section>

  <Section variant="soft" eyebrow={home.venue.eyebrow} title={home.venue.title} intro={home.venue.intro}>
    <div class="split venue-split">
      <VenueCollage photos={featuredVenuePhotos} />
      <div class="content">
        <h2>On-site experience</h2>
        <ul>
          <li>Registration opens at 8:30 AM in the Gala room foyer</li>
          <li>Single-room program flow with lunch and sponsor showcase</li>
          <li>Waterfront venue with breakout space for networking</li>
        </ul>
        <div class="about-actions">
          <Button href="/venue">{home.venue.cta}</Button>
        </div>
      </div>
    </div>
  </Section>

  <CtaBand
    eyebrow={home.cta.eyebrow}
    title={home.cta.title}
    body={home.cta.body}
    primaryLabel={home.cta.primaryCta}
    secondaryLabel={home.cta.secondaryCta}
  />
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }

  .about-copy {
    display: flex;
    flex-direction: column;
    align-self: center;
  }

  .about-title {
    margin: 0;
    max-width: 22ch;
    color: var(--color-navy);
    font-size: clamp(2rem, 4.2vw, 3.2rem);
    line-height: 1.02;
    letter-spacing: -0.045em;
  }

  .about-lead {
    margin: 18px 0 0;
    max-width: 46ch;
    color: var(--color-muted);
    font-size: clamp(1.02rem, 1.8vw, 1.12rem);
    line-height: 1.55;
  }

  .about-body {
    display: grid;
    gap: 16px;
    margin-top: 24px;
  }

  .about-body p {
    margin: 0;
    max-width: 58ch;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .about-highlights {
    margin: 22px 0 0;
    padding-left: 1.15rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .about-highlights li + li {
    margin-top: 10px;
  }

  .about-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .about-media {
    margin: 0;
    aspect-ratio: 4 / 5;
    max-height: min(560px, 72vh);
    justify-self: end;
    width: min(100%, 440px);
  }

  .about-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .venue-split {
    align-items: center;
  }

  .agenda-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .agenda-preview {
    display: grid;
    gap: 14px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .agenda-preview-item {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }

  .agenda-time {
    margin: 0;
    color: var(--color-brand);
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .agenda-preview-item h3 {
    margin: 0 0 8px;
    color: var(--color-navy);
    font-size: 1.15rem;
  }

  .agenda-preview-item p:last-child {
    margin: 0;
    color: var(--color-muted);
  }

  @media (max-width: 820px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .about-title {
      max-width: none;
    }

    .about-lead,
    .about-body p {
      max-width: none;
    }

    .about-media {
      justify-self: stretch;
      width: 100%;
      max-height: none;
      aspect-ratio: 5 / 4;
    }

    .agenda-preview-item {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
